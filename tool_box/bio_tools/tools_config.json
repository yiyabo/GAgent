                "requires_output": false,
                "extra_params": [
                    "output"
                ],
                "notes": "input: 输入FASTA文件; output: 输出目录名"
            }
        }
    },
    "checkv": {
        "image": "quay.io/biocontainers/checkv:1.0.1--pyhdfd78af_0",
        "description": "CheckV - 病毒基因组质量评估",
        "category": "phage",
        "notes": "需要数据库: /home/zczhao/GAgent/data/databases/bio_tools/checkv/checkv-db-v1.5 (~2GB)，容器内映射为 /work/database",
