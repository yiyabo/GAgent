{
    "seqkit": {
        "image": "staphb/seqkit:2.8.0",
        "description": "SeqKit - A cross-platform and ultrafast toolkit for FASTA/Q file manipulation",
        "category": "sequence_processing",
        "operations": {
            "stats": {
                "command": "seqkit stats {input}",
                "description": "统计序列文件信息（数量、长度、GC含量等）",
                "requires_input": true,
                "requires_output": false
            },
            "grep": {
                "command": "seqkit grep -p '{pattern}' {input} -o {output}",
                "description": "按模式搜索序列",
                "requires_input": true,
                "requires_output": true,
                "extra_params": [
                    "pattern"
                ]
            },
            "seq": {
                "command": "seqkit seq {input} -o {output}",
                "description": "序列格式转换和处理",
                "requires_input": true,
                "requires_output": true
            },
            "head": {
                "command": "seqkit head -n {count} {input}",
                "description": "显示前N条序列 (count=序列数量)",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "count"
                ]
            }
        }
    },
    "blast": {
        "image": "biocontainers/blast:2.2.31",
        "description": "BLAST+ - Basic Local Alignment Search Tool for sequence similarity search",
        "category": "sequence_alignment",
        "notes": "数据库必须先用 makeblastdb 创建，且路径必须使用容器内路径 /work/xxx",
        "operations": {
            "blastn": {
                "command": "blastn -query {input} -db {database} -out {output} -outfmt 6",
                "description": "核酸序列比对 (database 必须是 /work/xxx 格式的容器内路径)",
                "requires_input": true,
                "requires_output": true,
                "extra_params": [
                    "database"
                ],
                "notes": "database 参数必须使用容器内路径，如 /work/mydb (对应 runtime/bio_tools/blast/mydb)"
            },
            "blastp": {
                "command": "blastp -query {input} -db {database} -out {output} -outfmt 6",
                "description": "蛋白质序列比对 (database 必须是 /work/xxx 格式的容器内路径)",
                "requires_input": true,
                "requires_output": true,
                "extra_params": [
                    "database"
                ],
                "notes": "database 参数必须使用容器内路径，如 /work/mydb (对应 runtime/bio_tools/blast/mydb)"
            },
            "makeblastdb": {
                "command": "makeblastdb -in {input} -dbtype {dbtype} -out /work/{db_name}",
                "description": "创建 BLAST 数据库（输出到容器 /work 目录）",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "dbtype",
                    "db_name"
                ],
                "notes": "dbtype: nucl(核酸) 或 prot(蛋白质); db_name: 数据库名称，将保存在 runtime/bio_tools/blast/"
            }
        }
    },
    "prodigal": {
        "image": "docker.byoryn.cn/biocontainers/prodigal:v1-2.6.3-4-deb_cv1",
        "description": "Prodigal - Prokaryotic gene prediction",
        "category": "gene_prediction",
        "notes": "输出文件会保存到 runtime/bio_tools/prodigal/ 目录",
        "operations": {
            "predict": {
                "command": "prodigal -i {input} -o /dev/null -a /work/{protein_output} -d /work/{nucleotide_output}",
                "description": "预测原核生物基因，输出蛋白质和核苷酸序列",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "protein_output",
                    "nucleotide_output"
                ],
                "notes": "protein_output: 蛋白质输出文件名如 genes.faa; nucleotide_output: 核苷酸输出文件名如 genes.fna"
            },
            "meta": {
                "command": "prodigal -i {input} -o /dev/null -a /work/{protein_output} -p meta",
                "description": "宏基因组模式基因预测（适合短序列或宏基因组数据）",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "protein_output"
                ],
                "notes": "protein_output: 蛋白质输出文件名如 genes.faa; 适合序列数量多但单条序列较短的数据"
            }
        }
    },
    "hmmer": {
        "image": "staphb/hmmer:latest",
        "description": "HMMER - Biosequence analysis using profile hidden Markov models",
        "category": "sequence_analysis",
        "notes": "HMM数据库必须先用 hmmpress 处理，路径使用容器内路径 /work/xxx",
        "operations": {
            "hmmscan": {
                "command": "hmmscan --tblout /work/{output} {database} {input}",
                "description": "用序列搜索 HMM 数据库",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "database",
                    "output"
                ],
                "notes": "database: 使用容器内路径如 /work/Pfam-A.hmm; 数据库需先用 hmmpress 处理"
            },
            "hmmsearch": {
                "command": "hmmsearch --tblout /work/{output} {hmm_file} {input}",
                "description": "用 HMM 搜索序列数据库",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "hmm_file",
                    "output"
                ],
                "notes": "hmm_file: HMM配置文件路径; output: 输出文件名"
            },
            "hmmpress": {
                "command": "hmmpress /work/{hmm_file}",
                "description": "压缩/准备 HMM 数据库以供 hmmscan 使用",
                "requires_input": false,
                "requires_output": false,
                "extra_params": [
                    "hmm_file"
                ],
                "notes": "hmm_file: 放在 runtime/bio_tools/hmmer/ 目录下的 HMM 文件名"
            }
        }
    },
    "checkv": {
        "image": "quay.io/biocontainers/checkv:1.0.1--pyhdfd78af_0",
        "description": "CheckV - Assess the quality of metagenome-assembled viral genomes",
        "category": "virus_quality",
        "operations": {
            "end_to_end": {
                "command": "checkv end_to_end {input} {output_dir} -d {database}",
                "description": "完整的病毒基因组质量评估流程",
                "requires_input": true,
                "requires_output": true,
                "extra_params": [
                    "database"
                ]
            },
            "completeness": {
                "command": "checkv completeness {input} {output_dir} -d {database}",
                "description": "评估病毒基因组完整性",
                "requires_input": true,
                "requires_output": true,
                "extra_params": [
                    "database"
                ]
            }
        }
    }
}