                ],
                "notes": "input: bins目录; output: 输出统计文件; output_dir: 工作目录; 需 CheckM 数据库"
            },
            "qa": {
                "command": "checkm qa -o 2 -f /work/{output} --tabulated /work/{tree} {input}",
                "description": "详细质量评估",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output",
                    "tree",
                    "input"
                ],
                "notes": "tree: lineage_wf生成的tree文件; input: marker file; output: 输出文件"
            }
        }
    },
    "gtdbtk": {
        "image": "quay.io/biocontainers/gtdbtk:2.3.2--pyhdfd78af_0",
        "description": "GTDB-Tk - 基于系统发育的物种分类",
        "category": "taxonomy",
        "notes": "需要数据库: /home/zczhao/GAgent/data/databases/bio_tools/gtdbtk，容器内映射为 /work/database",
        "operations": {
            "classify_wf": {
                "command": "gtdbtk classify_wf --genome_dir {genome_dir} --out_dir /work/{output} --database /work/database -x fa",
                "description": "bins 物种分类",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "genome_dir",
                    "output"
                ],
                "notes": "genome_dir: bins目录(包含fa文件); output: 输出目录; 需 GTDB-Tk 数据库"
            }
        }
    },
    "genomad": {
        "image": "quay.io/biocontainers/genomad:1.7.6--pyhdfd78af_0",
        "description": "geNomad - 移动遗传元素识别（噬菌体/质粒预测）",
