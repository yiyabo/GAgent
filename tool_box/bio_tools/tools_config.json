{
    "seqkit": {
        "image": "staphb/seqkit:2.8.0",
        "description": "SeqKit - A cross-platform and ultrafast toolkit for FASTA/Q file manipulation",
        "category": "sequence_processing",
        "operations": {
            "stats": {
                "command": "seqkit stats {input}",
                "description": "统计序列文件信息（数量、长度、GC含量等）",
                "requires_input": true,
                "requires_output": false
            },
            "grep": {
                "command": "seqkit grep -p '{pattern}' {input} -o {output}",
                "description": "按模式搜索序列",
                "requires_input": true,
                "requires_output": true,
                "extra_params": [
                    "pattern"
                ]
            },
            "seq": {
                "command": "seqkit seq {input} -o {output}",
                "description": "序列格式转换和处理",
                "requires_input": true,
                "requires_output": true
            },
            "head": {
                "command": "seqkit head -n {count} {input}",
                "description": "显示前N条序列 (count=序列数量)",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "count"
                ]
            }
        }
    },
    "blast": {
        "image": "biocontainers/blast:2.2.31",
        "description": "BLAST+ - Basic Local Alignment Search Tool for sequence similarity search",
        "category": "sequence_alignment",
        "notes": "数据库必须先用 makeblastdb 创建，且路径必须使用容器内路径 /work/xxx",
        "operations": {
            "blastn": {
                "command": "blastn -query {input} -db {db} -out /work/{output} -outfmt 6",
                "description": "核酸序列比对",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "db",
                    "output"
                ],
                "notes": "db: 容器内路径如 /work/mydb; output: 输出文件名如 results.txt"
            },
            "blastp": {
                "command": "blastp -query {input} -db {db} -out /work/{output} -outfmt 6",
                "description": "蛋白质序列比对",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "db",
                    "output"
                ],
                "notes": "db: 容器内路径如 /work/mydb; output: 输出文件名如 results.txt"
            },
            "makeblastdb": {
                "command": "makeblastdb -in {input} -dbtype {type} -out /work/{db}",
                "description": "创建 BLAST 数据库",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "type",
                    "db"
                ],
                "notes": "type: nucl(核酸) 或 prot(蛋白质); db: 数据库名称(无后缀)"
            }
        }
    },
    "prodigal": {
        "image": "docker.byoryn.cn/biocontainers/prodigal:v1-2.6.3-4-deb_cv1",
        "description": "Prodigal - Prokaryotic gene prediction",
        "category": "gene_prediction",
        "notes": "输出文件会保存到 runtime/bio_tools/prodigal/ 目录",
        "operations": {
            "predict": {
                "command": "prodigal -i {input} -o /dev/null -a /work/{protein} -d /work/{nucleotide}",
                "description": "预测原核生物基因",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "protein",
                    "nucleotide"
                ],
                "notes": "protein: 蛋白质输出文件名如 genes.faa; nucleotide: 核苷酸输出文件名如 genes.fna"
            },
            "meta": {
                "command": "prodigal -i {input} -o /dev/null -a /work/{protein} -p meta",
                "description": "宏基因组模式基因预测",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "protein"
                ],
                "notes": "protein: 蛋白质输出文件名如 genes.faa; 适合短序列或宏基因组数据"
            }
        }
    },
    "hmmer": {
        "image": "staphb/hmmer:latest",
        "description": "HMMER - Biosequence analysis using profile hidden Markov models",
        "category": "sequence_analysis",
        "notes": "HMM数据库必须先用 hmmpress 处理。支持绝对路径（自动挂载）或放在 runtime/bio_tools/hmmer/ 目录下的文件名",
        "operations": {
            "hmmscan": {
                "command": "hmmscan --tblout /work/{output} {db} {input}",
                "description": "用序列搜索 HMM 数据库",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "db",
                    "output"
                ],
                "notes": "db: 支持绝对路径如 /home/xxx/xxx.hmm 或相对路径（放 runtime/bio_tools/hmmer/ 目录）; output: 输出文件名"
            },
            "hmmsearch": {
                "command": "hmmsearch --tblout /work/{output} {db} {input}",
                "description": "用 HMM 搜索序列数据库",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "db",
                    "output"
                ],
                "notes": "db: 支持绝对路径如 /home/xxx/xxx.hmm 或相对路径（放 runtime/bio_tools/hmmer/ 目录）; output: 输出文件名"
            },
            "hmmpress": {
                "command": "hmmpress /work/{db}",
                "description": "压缩/准备 HMM 数据库以供 hmmscan 使用",
                "requires_input": false,
                "requires_output": false,
                "extra_params": [
                    "db"
                ],
                "notes": "db: 放在 runtime/bio_tools/hmmer/ 目录下的 HMM 文件名"
            },
            "hmmbuild": {
                "command": "hmmbuild /work/{output} {input}",
                "description": "从序列比对构建 HMM 模型",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output"
                ],
                "notes": "output: 输出 HMM 文件名如 test.hmm; input 应该是对齐好的 FASTA/Stockholm/Clustal/Phylip 文件"
            }
        }
    },
    "dorado": {
        "image": "genomicpariscentre/dorado:0.5.3",
        "description": "Dorado - Oxford Nanopore basecalling and demultiplexing",
        "category": "long_read_processing",
        "notes": "长读长数据处理：basecall + demux。GPU可用时更快，需安装NVIDIA Container Toolkit",
        "operations": {
            "basecall": {
                "command": "/opt/dorado-0.5.3-linux-x64/bin/dorado basecall --model {model} --kit-name {kit} --output-dir /work/{output} {input}",
                "description": "Nanopore 原始信号 basecalling",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "model",
                    "kit",
                    "output"
                ],
                "notes": "model: 模型如 dna_r10.4.1_e8.1_sup; kit: 试剂盒如 SQK-RBK001; output: 输出目录名"
            },
            "demux": {
                "command": "/opt/dorado-0.5.3-linux-x64/bin/dorado demux --output-dir /work/{output_dir} --kit-name {kit} {input}",
                "description": "拆分多样本 barcode 数据",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "kit",
                    "output_dir"
                ],
                "notes": "kit: 试剂盒如 SQK-RBK001, SQK-NBD114-96; output_dir: 输出目录名"
            }
        }
    },
    "nanoplot": {
        "image": "staphb/nanoplot:latest",
        "description": "NanoPlot - 长读长测序数据质控可视化",
        "category": "long_read_processing",
        "notes": "输入支持: --fastq, --fasta, --bam, --summary",
        "operations": {
            "basic": {
                "command": "NanoPlot --fastq {input} -o /work/{output} --prefix {prefix}",
                "description": "长读长数据质控和可视化",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output",
                    "prefix"
                ],
                "notes": "output: 输出目录; prefix: 输出文件前缀; 输入文件放在 runtime/bio_tools/nanoplot/input/"
            }
        }
    },
    "minimap2": {
        "image": "staphb/minimap2:latest",
        "description": "Minimap2 - 短读长/长读长快速比对工具",
        "category": "sequence_alignment",
        "notes": "支持: map-pb (PacBio), map-ont (ONT), map-hifi (HiFi), sr (短读长)",
        "operations": {
            "map": {
                "command": "minimap2 -ax {preset} {reference} {query} > /work/{output}",
                "description": "序列比对",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "preset",
                    "reference",
                    "output"
                ],
                "notes": "preset: map-pb/map-ont/map-hifi/sr; reference: 参考基因组路径; output: SAM输出文件名"
            },
            "filter": {
                "command": "minimap2 -t {threads} -ax map-ont {reference} {input} > /work/{output}",
                "description": "比对到参考基因组，输出 SAM/BAM（供 samtools 过滤未比对 reads）",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "reference",
                    "output",
                    "threads"
                ],
                "notes": "reference: 参考基因组(.mmi); output: 输出SAM文件; 需配合 samtools 提取未比对 reads"
            }
        }
    },
    "samtools": {
        "image": "staphb/samtools:latest",
        "description": "SAMtools - 处理 SAM/BAM/CRAM 文件",
        "category": "sequence_alignment",
        "notes": "用于处理比对结果，支持 view/sort/index/fastq 等操作",
        "operations": {
            "view_filter_unmapped": {
                "command": "samtools view -@ {threads} -b -f 4 {input} | samtools fastq -@ {threads} - | gzip -c > /work/{output}",
                "description": "提取未比对 reads（-f 4），输出 FASTQ.gz",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "threads",
                    "output"
                ],
                "notes": "input: SAM/BAM文件; output: 输出FASTQ.gz; -f 4 保留未比对 reads"
            },
            "view": {
                "command": "samtools view -@ {threads} -b {input} > /work/{output}",
                "description": "SAM 转 BAM",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "threads",
                    "output"
                ],
                "notes": "input: SAM文件; output: 输出BAM文件"
            },
            "sort": {
                "command": "samtools sort -@ {threads} {input} -o /work/{output}",
                "description": "排序 BAM 文件",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "threads",
                    "output"
                ],
                "notes": "input: BAM文件; output: 排序后BAM文件"
            },
            "index": {
                "command": "samtools index {input}",
                "description": "为 BAM 文件建立索引",
                "requires_input": true,
                "requires_output": false,
                "notes": "input: BAM文件; 输出: .bai 索引文件"
            },
            "stats": {
                "command": "samtools stats {input} > /work/{output}",
                "description": "比对统计报告",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output"
                ],
                "notes": "input: SAM/BAM文件; output: 统计报告"
            }
        }
    },
    "flye": {
        "image": "staphb/flye:latest",
        "description": "Flye - 长读长组装工具（支持 meta 宏基因组模式）",
        "category": "assembly",
        "notes": "ONT/PacBio/HiFi 长读长组装，meta 模式适合宏基因组",
        "operations": {
            "meta": {
                "command": "flye --meta --out-dir {output} {input}",
                "description": "宏基因组模式组装（ONT 推荐）",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output"
                ],
                "notes": "input: ONT reads (fastq); output: 输出目录; 需要配合 --nano-raw 参数; 结果在 assembly.fasta"
            },
            "ont": {
                "command": "flye --nano-raw --out-dir {output} {input}",
                "description": "ONT 原始数据组装",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output"
                ],
                "notes": "input: ONT fastq; output: 输出目录"
            },
            "hifi": {
                "command": "flye --pacbio-hifi --out-dir {output} {input}",
                "description": "HiFi 模式组装",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output"
                ],
                "notes": "input: HiFi reads; output: 输出目录"
            }
        }
    },
    "seqtk": {
        "image": "staphb/seqtk:latest",
        "description": "Seqtk -  FASTA/Q 工具",
        "category": "sequence_processing",
        "notes": "支持子采样、序列处理等",
        "operations": {
            "sample": {
                "command": "seqtk sample {input} {fraction} > /work/{output}",
                "description": "随机抽样序列",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "fraction",
                    "output"
                ],
                "notes": "fraction: 抽样比例(0-1)如 0.1 表示10%; output: 输出文件名"
            },
            "size": {
                "command": "seqtk size {input}",
                "description": "统计序列数量和碱基数",
                "requires_input": true,
                "requires_output": false
            }
        }
    },
    "megahit": {
        "image": "quay.io/biocontainers/megahit:1.2.9--h43eeafb_5",
        "description": "MEGAHIT - 宏基因组组装工具",
        "category": "assembly",
        "notes": "短读长宏基因组组装首选",
        "operations": {
            "assemble": {
                "command": "megahit -1 {r1} -2 {r2} -o /work/{output}",
                "description": "短读长宏基因组组装",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "r1",
                    "r2",
                    "output"
                ],
                "notes": "r1/r2: 双端测序文件路径; output: 输出目录名; 结果保存到 runtime/bio_tools/megahit/output/"
            }
        }
    },
    "bakta": {
        "image": "staphb/bakta:latest",
        "description": "Bakta - 细菌基因组快速标准化注释",
        "category": "annotation",
        "notes": "需要数据库: /home/zczhao/GAgent/data/databases/bio_tools/bakta_db，容器内映射为 /work/database",
        "operations": {
            "annotate": {
                "command": "bakta --db /work/database --prefix {prefix} --output-dir /work/{output} {input}",
                "description": "基因组/宏基因组注释",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "prefix",
                    "output"
                ],
                "notes": "prefix: 输出前缀; output: 输出目录名; 需 Bakta 数据库"
            }
        }
    },
    "metabat2": {
        "image": "quay.io/biocontainers/metabat2:2.15--h986a166_1",
        "description": "MetaBAT2 - 宏基因组分箱工具",
        "category": "binning",
        "notes": "依赖 contig depth 文件 (用 jgi_summarize_bam_contig_depths 生成)",
        "operations": {
            "bin": {
                "command": "metabat2 -i {contigs} -a {depth} -o /work/{output_prefix}",
                "description": "基于丰度分箱",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "contigs",
                    "depth",
                    "output_prefix"
                ],
                "notes": "contigs: 组装结果contigs路径; depth: depth文件路径; output_prefix: 输出前缀"
            },
            "depth": {
                "command": "jgi_summarize_bam_contig_depths --outputDepth /work/{output} {bam_files}",
                "description": "计算 contig 丰度深度",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output",
                    "bam_files"
                ],
                "notes": "output: depth输出文件名; bam: 排序后的bam文件列表(空格分隔)"
            }
        }
    },
    "concoct": {
        "image": "quay.io/biocontainers/concoct:1.1.0--py312h71dcd68_8",
        "description": "CONCOCT - 基于组成和丰度的宏基因组分箱",
        "category": "binning",
        "notes": "需要先准备 coverage table",
        "operations": {
            "bin": {
                "command": "concoct --coverage_file /work/{coverage} --contigs_file {contigs} -b /work/{output}",
                "description": "宏基因组分箱",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "coverage",
                    "contigs",
                    "output"
                ],
                "notes": "coverage: coverage table路径; contigs: contigs fasta路径; output: 输出目录"
            }
        }
    },
    "maxbin2": {
        "image": "quay.io/biocontainers/maxbin2:2.2.7--he1b5a44_2",
        "description": "MaxBin2 - 宏基因组分箱工具",
        "category": "binning",
        "notes": "需要 abundance 信息文件",
        "operations": {
            "bin": {
                "command": "run_MaxBin.pl -contig {contigs} -out /work/{output} -abundance {abundance}",
                "description": "宏基因组分箱",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "contigs",
                    "output",
                    "abundance"
                ],
                "notes": "contigs: 组装结果; output: 输出前缀; abundance: 丰度文件"
            }
        }
    },
    "das_tool": {
        "image": "quay.io/biocontainers/das_tool:1.1.6--r42hdfd78af_0",
        "description": "DAS Tool - 整合多个分箱结果",
        "category": "binning",
        "notes": "整合 MetaBAT2/CONCOCT/MaxBin 等结果",
        "operations": {
            "integrate": {
                "command": "DAS_Tool -i {bins} -c {contigs} -o /work/{output}",
                "description": "整合分箱结果",
                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "bins",
                    "contigs",
                    "output"
                ],
                "notes": "bins: 各工具bin文件列表(逗号分隔); contigs: 组装结果; output: 输出前缀"
            }
        }
    },
    "checkm": {
        "image": "staphb/checkm:latest",
        "description": "CheckM - 宏基因组组装基因组质量评估",
        "category": "bin_assessment",
        "notes": "需要数据库: /home/zczhao/GAgent/data/databases/bio_tools/checkm_data，容器内映射为 /work/database",
        "operations": {
            "lineage_wf": {
                "command": "checkm lineage_wf -x fa --tabulated -f /work/{output} --database /work/database {input} /work/{output_dir}",
