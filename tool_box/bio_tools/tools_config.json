                "requires_input": true,
                "requires_output": false,
                "extra_params": [
                    "output"
                ],
                "notes": "input: 输入FASTA文件; output: 输出目录名; 需 geNomad 数据库"
            },
            "annotate": {
                "command": "genomad annotate {input} /work/{output} /work/database",
